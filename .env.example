# SAP Build Work Zone - Card Repository API Configuration
# Copy this file to .env and fill in your values

# OAuth2 Client Credentials (from Service Key)
CLIENT_ID=sb-xxxxxxxx
CLIENT_SECRET=xxxxxxxx
TOKEN_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token

# Card Repository API endpoint (from Service Key endpoints)
CARD_REPO_URL=https://<your-workzone-host>/integration/v1/cardstore/cards