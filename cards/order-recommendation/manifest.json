{
	"_version": "1.15.0",
	"sap.app": {
		"id": "store.ai.card.orderrecommendation",
		"type": "card",
		"title": "AI Order Recommendation",
		"subTitle": "AI 발주 추천 Top 5",
		"applicationVersion": {
			"version": "1.0.0"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {"desktop": true, "phone": true, "tablet": true},
		"icons": {
			"icon": "sap-icon://shipping-status"
		}
	},
	"sap.ui5": {
		"rootView": {
			"viewName": "store.ai.card.orderrecommendation.View",
			"type": "XML",
			"async": true,
			"id": "app"
		},
		"dependencies": {
			"minUI5Version": "1.38",
			"libs": {
				"sap.m": {}
			}
		}
	},
	"sap.card": {
		"type": "Component",
		"designtime": "dt/configuration",
		"header": {
			"icon": {
				"src": "sap-icon://shipping-status"
			},
			"title": "🎯 AI 발주 추천 Top 5",
			"subTitle": "우선순위 기반 발주 추천"
		}
	},
	"sap.platform.mobilecards": {
		"compatible": false
	}
}