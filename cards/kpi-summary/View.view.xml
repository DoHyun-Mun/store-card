<mvc:View xmlns:core="sap.ui.core"
          xmlns:mvc="sap.ui.core.mvc"
          xmlns="sap.m"
          xmlns:html="http://www.w3.org/1999/xhtml"
          width="100%"
          controllerName="store.ai.card.kpisummary.Card">
    <html:style>
        .kpiRow {
            display: flex;
            gap: 0.6rem;
            padding: 0.75rem;
            font-family: "Inter", "72", sans-serif;
        }
        .kpiCard {
            flex: 1 1 0;
            min-width: 0;
            background: #fff;
            border: 1px solid #E5E8ED;
            border-radius: 12px;
            padding: 1rem 1.15rem;
            display: flex;
            align-items: center;
            gap: 0.85rem;
            box-shadow: 0 1px 4px rgba(29,45,62,0.06);
        }
        .kpiCard.highlight {
            border: 2px solid #D93025;
            background: #FFF8F7;
        }
        .kpiIconWrap {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        .kpiBody { display: flex; flex-direction: column; }
        .kpiValue { font-size: 1.35rem; font-weight: 700; line-height: 1.2; color: #1D2D3E; }
        .kpiLabel { font-size: 0.7rem; font-weight: 500; color: #8396A8; margin-top: 0.1rem; }
        .kpiChangeDown { font-size: 0.68rem; font-weight: 600; color: #D93025; margin-top: 0.15rem; }
        .kpiSublabel { font-size: 0.62rem; color: #8396A8; margin-top: 0.1rem; }
    </html:style>
    <html:div class="kpiRow">
        <html:div class="kpiCard">
            <html:div class="kpiIconWrap" style="background:#EBF3FE;color:#0070F2">💰</html:div>
            <html:div class="kpiBody">
                <html:span class="kpiValue">₩1.8억</html:span>
                <html:span class="kpiLabel">최근 매출</html:span>
                <html:span class="kpiChangeDown">↓ 전일 대비 -0.7%</html:span>
            </html:div>
        </html:div>
        <html:div class="kpiCard">
            <html:div class="kpiIconWrap" style="background:#E6F4EA;color:#188038">🏥</html:div>
            <html:div class="kpiBody">
                <html:span class="kpiValue">72점</html:span>
                <html:span class="kpiLabel">재고 건전성</html:span>
                <html:span class="kpiChangeDown">↓ 3</html:span>
            </html:div>
        </html:div>
        <html:div class="kpiCard">
            <html:div class="kpiIconWrap" style="background:#FCE8E6;color:#D93025">🚨</html:div>
            <html:div class="kpiBody">
                <html:span class="kpiValue">192건</html:span>
                <html:span class="kpiLabel">결품 위험</html:span>
                <html:span class="kpiSublabel">즉시 조치 →</html:span>
            </html:div>
        </html:div>
        <html:div class="kpiCard highlight">
            <html:div class="kpiIconWrap" style="background:#FEF3E0;color:#E37400">📋</html:div>
            <html:div class="kpiBody">
                <html:span class="kpiValue">14건</html:span>
                <html:span class="kpiLabel">발주 대기</html:span>
                <html:span class="kpiSublabel">승인 필요 →</html:span>
            </html:div>
        </html:div>
    </html:div>
</mvc:View>