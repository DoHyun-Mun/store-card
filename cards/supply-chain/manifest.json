{
	"_version": "1.15.0",
	"sap.app": {
		"id": "store.ai.card.supplychain",
		"type": "card",
		"title": "Supply Chain",
		"subTitle": "공급망 네트워크",
		"applicationVersion": {
			"version": "1.0.0"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {"desktop": true, "phone": true, "tablet": true},
		"icons": {
			"icon": "sap-icon://connected"
		}
	},
	"sap.ui5": {
		"rootView": {
			"viewName": "store.ai.card.supplychain.View",
			"type": "XML",
			"async": true,
			"id": "app"
		},
		"dependencies": {
			"minUI5Version": "1.38",
			"libs": {
				"sap.m": {}
			}
		}
	},
	"sap.card": {
		"type": "Component",
		"designtime": "dt/configuration",
		"header": {
			"icon": {
				"src": "sap-icon://connected"
			},
			"title": "🔗 공급망 네트워크",
			"subTitle": "위험 경로 시각화"
		}
	},
	"sap.platform.mobilecards": {
		"compatible": false
	}
}